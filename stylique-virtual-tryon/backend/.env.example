PORT=5000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
JWT_SECRET=change-this-to-a-random-secret
FRONTEND_URL=http://localhost:3000

# AWS Rekognition (optional – mock scoring used when absent)
# Supported regions for Rekognition: us-east-1, us-west-2, eu-west-1, ap-southeast-1, etc.
# See docs/AWS_CONFIG.md for the chosen region and reasoning.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1

# Shopify OAuth + Admin API (Partner Dashboard → App → Client credentials)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Comma-separated scopes. Include read_themes,write_themes for auto theme injection.
SHOPIFY_SCOPES=read_products,write_products,read_themes,write_themes
# Must match the “Allowed redirection URL(s)” in the Shopify app settings exactly
SHOPIFY_REDIRECT_URI=http://localhost:5000/api/shopify/callback
# Public base URL of this API (HTTPS in production) — used for webhook registration
PUBLIC_API_URL=http://localhost:5000

# Optional: scripts/shopify-e2e-product.mjs (create product + poll inventory for webhook)
# SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
# SHOPIFY_ACCESS_TOKEN=   # omit to load token from Supabase after OAuth
# Optional override for webhook address base only
# SHOPIFY_WEBHOOK_BASE_URL=https://api.yourdomain.com
# Admin API version segment (default 2024-10)
# SHOPIFY_API_VERSION=2024-10
