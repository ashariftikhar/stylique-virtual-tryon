    font-weight: 600;
    color: #475569;
    width: 80px;
    flex-shrink: 0;
  }

  .stylique-fit-value {
    font-size: 0.875rem;
    color: #0f172a;
    font-weight: 500;
  }

  .stylique-alt-sizes-grid {
