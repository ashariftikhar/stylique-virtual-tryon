  }
  .stylique-dot-good { background: #10b981; box-shadow: 0 0 6px rgba(16,185,129,0.3); }
  .stylique-dot-bad { background: #ef4444; box-shadow: 0 0 6px rgba(239,68,68,0.3); }
  .stylique-dot-warn { background: #f59e0b; box-shadow: 0 0 6px rgba(245,158,11,0.3); }
  .stylique-dot-neutral { background: #cbd5e1; }

