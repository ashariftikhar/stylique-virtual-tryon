  .stylique-alt-card {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 14px;
    transition: border-color 0.2s;
  }
  .stylique-alt-card:hover { border-color: #cbd5e1; }

  .stylique-alt-title {
    display: block;
    font-weight: 700;
    color: #0f172a;
    font-size: 0.875rem;
